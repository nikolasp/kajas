{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kajas",
  "version": "0.1.0",
  "identifier": "dev.kajas.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/kajas-backend"],
    "resources": ["../dist"]
  }
}
